# =========================================
# SamBee — шаблон змінних середовища
# Скопіюй цей файл: cp .env.example .env
# Заповни своїми значеннями у .env
# =========================================

# --- База даних PostgreSQL ---
# Якщо запускаєш через Docker Compose — хост = "postgres" (назва сервісу)
# Якщо запускаєш локально — хост = "localhost"
POSTGRES_USER=sambee
POSTGRES_PASSWORD=sambee
POSTGRES_DB=sambee
DATABASE_URL=postgresql+asyncpg://sambee:sambee@postgres:5432/sambee

# --- MQTT брокер ---
# Якщо запускаєш через Docker Compose — хост = "mosquitto"
# Якщо запускаєш локально — хост = "localhost"
MQTT_HOST=mosquitto
MQTT_PORT=1883

# --- Frontend ---
# URL бекенду для браузера (завжди localhost, бо браузер не в Docker-мережі)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Безпека ---
# SECRET_KEY використовується для підпису JWT токенів
# Згенеруй випадковий рядок: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
