#pragma once

#define WIFI_SSID      "YOUR_WIFI_NAME"
#define WIFI_PASSWORD  "YOUR_WIFI_PASSWORD"
#define MQTT_HOST      "192.168.1.100"
#define MQTT_PORT      1883
#define HIVE_ID        "hive_01"

// HX711 calibration factor (raw units per kg).
// How to find your value:
//   1. Set WEIGHT_CALIBRATION_FACTOR 1.0 and flash
//   2. Power on — tare happens automatically on boot
//   3. Place a known weight (e.g. 5.000 kg) on the scale
//   4. Read the printed raw value from Serial monitor
//   5. WEIGHT_CALIBRATION_FACTOR = raw_value / known_kg
#define WEIGHT_CALIBRATION_FACTOR 1.0f